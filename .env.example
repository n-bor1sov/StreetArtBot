BOT_TOKEN=your_telegram_bot_token_here

# Local:
# MONGO_URL=mongodb://localhost:27017/street_art_bot

# MongoDB Atlas (mongodb+srv). Put the whole URL in quotes if it contains &.
# Database name is taken from the path (/TarifAuction below). Override with MONGO_DB_NAME if needed.
MONGO_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/TarifAuction?retryWrites=true&w=majority"

# Optional: force DB name when URI has no path or you want another database
# MONGO_DB_NAME=street_art_bot

ADMIN_IDS=[894797521,230394949,202535047,452422342]
LOG_LEVEL=INFO
ASSETS_DIR=assets
